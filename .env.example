# SaSLoop — Production Environment Template
# Copy this to .env on your Oracle Cloud VM

# --- SERVER SETTINGS ---
PORT=5000
NODE_ENV=production
JWT_SECRET=PASTE_A_RANDOM_LONG_STRING_HERE

# --- DATABASE ---
# Local VM Postgres
DB_USER=postgres
DB_PASSWORD=shahi
DB_NAME=SaSLoop
DB_HOST=localhost
DB_PORT=5432
# OR use a Connection String (Recommended for Neon/Managed DB)
# DATABASE_URL=postgres://user:pass@host:5432/dbname?ssl=true

# --- AI & EXTERNAL APIS ---
GROQ_API_KEY=your_groq_key_here
META_VERIFY_TOKEN=sasloop_verify_token

# --- NGROK (IF USING STATIC DOMAIN ON VM) ---
NGROK_AUTHTOKEN=your_ngrok_token_here
NGROK_DOMAIN=sasloop.ngrok-free.app
