# SaSLoop Production Environment Configuration Example
# Copy this to .env and fill in the values

# Server Port
PORT=5000

# Security
JWT_SECRET=your_production_secure_secret_here

# Database (PostgreSQL)
DB_USER=sasloop_admin
DB_HOST=localhost
DB_NAME=sasloop_db
DB_PASS=strong_password_here
DB_PORT=5432

# Meta WhatsApp Cloud API (Primary/Global System)
# These are used as defaults if business-specific ones are not set
META_ACCESS_TOKEN=EA...
META_PHONE_ID=108...
META_ACCOUNT_ID=...
META_VERIFY_TOKEN=sasloop_verify_token

# AI Processing (Groq is used for high-speed Llama 3 processing)
GROQ_API_KEY=gsk_...

# Other settings
NODE_ENV=production
